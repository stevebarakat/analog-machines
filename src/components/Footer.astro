---
const year = new Date().getFullYear();
---

<footer
  class="bg-analog-black border-t border-analog-gold/30 mt-12 py-8 text-center text-analog-cream/60"
>
  <div class="container mx-auto px-4">
    <p class="font-mono text-sm">
      &copy; {year} Analog Machines. Hand-wired in the void.
    </p>
    <div
      class="flex justify-center space-x-4 mt-4 text-xs uppercase tracking-widest"
    >
      <a href="#" class="hover:text-analog-gold">Instagram</a>
      <span class="text-analog-gold/30">|</span>
      <a href="#" class="hover:text-analog-gold">Twitter</a>
      <span class="text-analog-gold/30">|</span>
      <a href="#" class="hover:text-analog-gold">Email</a>
    </div>
  </div>
</footer>
