---
interface Props {
    product: {
        id: number;
        name: string;
        slug: string;
        price: number;
        images: { src: string; alt: string }[];
        short_description: string;
    }
}

const { product } = Astro.props;
---

<a href={`/product/${product.slug}`} class="block group">
    <div class="bg-analog-black border border-analog-gold/20 p-4 rounded-lg transition-all hover:border-analog-gold hover:shadow-[0_0_15px_rgba(197,160,89,0.2)] hover:-translate-y-1">
        <div class="aspect-video bg-black/50 mb-4 overflow-hidden rounded relative">
            <img 
                src={product.images[0].src} 
                alt={product.images[0].alt} 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute inset-0 bg-analog-gold/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
        
        <h3 class="text-xl font-serif font-bold text-analog-cream mb-1 group-hover:text-analog-gold transition-colors">{product.name}</h3>
        <p class="font-mono text-analog-gold text-lg mb-2">${product.price}</p>
        <p class="text-sm text-gray-400 line-clamp-2">{product.short_description}</p>
        
        <div class="mt-4 inline-block text-xs font-mono uppercase border-b border-transparent group-hover:border-analog-gold text-analog-gold/80">
            View Specs ->
        </div>
    </div>
</a>
