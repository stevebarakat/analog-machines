}

const { name, class: className = "" } = Astro.props;

const paths: Record<string, string> = {
  electric_bolt: "M7 2v11h3v9l7-12h-4l4-8z",
  graphic_eq:
    "M7 18h2V6H7v12zm4 0h2v-5h-2v5zm4 0h2V9h-2v9z",
  check_circle:
    "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-7 9z",
  thermostat:
    "M15 13V5c0-1.66-1.34-3-3-3S9 3.34 9 5v8c-1.21.91-2 2.37-2 4 0 2.76 2.24 5 5 5s5-2.24 5-5c0-1.63-.79-3.09-2-4zm-4-8c0-.55.45-1 1-1s1 .45 1 1h-1v1h1v2h-1v1h1v2h-2V5z",
};
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="currentColor"
  class={className}
  aria-hidden="true"
  focusable="false"
>
  <path d={paths[name]} />
</svg>
