---
import "../styles/global.css";

// Import font URLs so Vite resolves the content-hashed paths at build time,
// letting us emit <link rel="preload"> in <head> without a CSS → font chain.
import interLatin400 from "@fontsource/inter/files/inter-latin-400-normal.woff2?url";
import interLatin300 from "@fontsource/inter/files/inter-latin-300-normal.woff2?url";
import interLatin600 from "@fontsource/inter/files/inter-latin-600-normal.woff2?url";
import playfairLatin700 from "@fontsource/playfair-display/files/playfair-display-latin-700-normal.woff2?url";
import spaceMono400 from "@fontsource/space-mono/files/space-mono-latin-400-normal.woff2?url";
import spaceMono700 from "@fontsource/space-mono/files/space-mono-latin-700-normal.woff2?url";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Analog Machines Audio | Boutique Analog Synthesis — hand-wired instruments built with discrete circuitry for the unpredictable beauty of voltage drift.",
  ogImage = "/images/analog-darkness.webp",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://analog-heaven.vercel.app");
const pageTitle = `${title} | Analog Machines Audio`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Font preloads — breaks the HTML → CSS → font chain so all
         six woff2 files are fetched in parallel with the CSS. -->
    <link rel="preload" as="font" type="font/woff2" crossorigin href={interLatin400} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={interLatin300} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={interLatin600} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={playfairLatin700} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={spaceMono400} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={spaceMono700} />

    <title>{pageTitle}</title>
    <slot name="head" />
  </head>
  <body class="bg-[#0d0d0d] text-[#e5e5e5] font-sans overflow-x-hidden">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-amber-500 focus:text-black focus:px-4 focus:py-2 focus:font-mono focus:text-sm focus:uppercase"
    >
      Skip to main content
    </a>
    <main id="main-content">
      <slot />
    </main>
  </body>
</html>
